3:50.143Z","categories_index":"数据库","tags_index":"关系型数据库","author_index":"Hyc"},{"id":"cb9e42289cdb9a60b927622274510084","title":"Mongodb","content":"","slug":"数据库/NoSQL/Mongdb/Mongodb","date":"2022-07-19T12:33:50.140Z","categories_index":"数据库","tags_index":"NoSQL","author_index":"Hyc"},{"id":"b6845422ba4775a7cab0c414606e3ecd","title":"Redis基础","content":"","slug":"数据库/NoSQL/Redis/Redis基础","date":"2022-07-19T12:33:50.140Z","categories_index":"数据库","tags_index":"NoSQL","author_index":"Hyc"},{"id":"4a207b7e885fdbcca8129599135e5f2e","title":"MySQL基础","content":"","slug":"数据库/关系型数据库/MySQL/MySQL基础","date":"2022-07-19T12:33:50.140Z","categories_index":"数据库","tags_index":"关系型数据库","author_index":"Hyc"},{"id":"6f4f974e39a23a6637b9ccfa82544a76","title":"Maven","content":"","slug":"常用工具&技术/Maven","date":"2022-07-19T12:33:50.130Z","categories_index":"常用工具&技术","tags_index":"","author_index":"Hyc"},{"id":"221a7ad001c03569112f684b2dfdc120","title":"Git","content":"Git简介Git是世界上最先进的分布式版本控制系统。\n版本控制是一种在开发的过程中用于管理我们对文件，目录或工程等内容的修改历史，方便查看更改历史记录，备份以便恢复到以前版本的软件工程技术。\nGit历史Linus在1991年开源了Linux。世界各地的开发者们都在为Linux的发展做出贡献。\n2002年以前，世界各地的开发者是通过diff的方式发送给Linus，然后Linus手动合并代码。随着Linux的发展，代码量庞大，很难再通过手工的方式管理。\n当时有很多免费的版本控制系统如：CVS，SVN。但是Linus坚决不使用因为这些集中式版本控制系统不但速度慢，而且必须联网才能使用。还有一些商用版本的控制系统，但是和Linux的开源精神不符。\n后来还是选择了商用版本的BitKeeper，BitKeeper出于人道主义精神，授权Linux社区免费使用。\n2005年，Linux社区牛人试图破解BitKeeper协议，被发现，便收回了免费使用的权限。\nLinus便花了两周时间，用C开发了一个分布式版本控制系统——Git。之后Linux的代码便都交给了Git管理。\n2008年，GitHub上线，并为开源项目提供了免费的Git存储，从此无数的开源项目迁移到GitHub中。\n集中式和分布式集中式集中式版本控制系统，版本库是集中放在中央服务器的，干活的时候，需要从中央服务器拉去最新的代码，编写完代码之后再提交回中央仓库。\n集中式最大的毛病就是必须联网才能使用。\n分布式分布式系统根本没有中央服务器（线上仓库可以理解为就是为了交换和你同事的代码），每个人的电脑上都是一个完整的库，这样你工作时就不需要联网了，版本库就在自己的电脑上。\n分布式版本控制系统相对与集中式版本控制系统要安全很多，因为每个人的电脑上都是一个版本库，而集中式版本控制系统如果服务器损坏就有可能代码丢失无法工作。\n\n\n\n\n\n\n\n\n\n\n假设SVN服务器没了，那你丢掉了所有历史信息，因为你的本地只有当前版本以及部分历史信息。\n假设GitHub服务器没了，你不会丢掉任何git历史信息，因为你的本地有完整的版本库信息。你可以把本地的git库重新上传到另外的git服务商。\n\nGit安装和配置官网：Git (git-scm.com)\nWindosw\n官网下载\n无脑下一步即可\n验证：终端输入git\n\nLinux1.\nMac1.\n","slug":"常用工具&技术/Git","date":"2022-07-19T12:33:50.130Z","categories_index":"常用工具&技术","tags_index":"","author_index":"Hyc"},{"id":"f73a8e23e6f6f669cf99c7dba8fa0722","title":"","content":"","slug":"Java/Java基础/JavaEE","date":"2022-07-19T12:33:50.130Z","categories_index":"","tags_index":"","author_index":"Hyc"},{"id":"0b1381c4a63c09e41167c5168339035a","title":"JVM","content":"","slug":"Java/Java进阶/JVM","date":"2022-07-19T12:33:50.130Z","categories_index":"Java进阶","tags_index":"","author_index":"Hyc"},{"id":"b75886c0afb407e68f01ccd196e5f24b","title":"Java版本新特性","content":"","slug":"Java/Java进阶/Java版本新特性","date":"2022-07-19T12:33:50.130Z","categories_index":"Java进阶","tags_index":"","author_index":"Hyc"},{"id":"9b79b6fb7568108556e9bc3e70a76e2d","title":"MyBatis-Plus","content":"","slug":"Java/Java进阶/MyBatis-Plus","date":"2022-07-19T12:33:50.130Z","categories_index":"Java框架","tags_index":"Java框架","author_index":"Hyc"},{"id":"e57105f5b8458f8b35842b2245e613d6","title":"Java设计模式","content":"","slug":"Java/Java进阶/Java设计模式","date":"2022-07-19T12:33:50.130Z","categories_index":"Java进阶","tags_index":"设计模式","author_index":"Hyc"},{"id":"7a897380fbf2b52c7fdc533d413e1985","title":"MyBatis","content":"","slug":"Java/Java进阶/MyBatis","date":"2022-07-19T12:33:50.130Z","categories_index":"Java框架","tags_index":"Java框架","author_index":"Hyc"},{"id":"946249c65165e1a3d66f50e0cb6e89e7","title":"Spring","content":"","slug":"Java/Java进阶/Spring","date":"2022-07-19T12:33:50.130Z","categories_index":"Java框架","tags_index":"Java框架","author_index":"Hyc"},{"id":"46d3e14db35995d713fed042cf2dff6b","title":"Netty","content":"","slug":"Java/Java进阶/Netty","date":"2022-07-19T12:33:50.130Z","categories_index":"Java框架","tags_index":"Java框架","author_index":"Hyc"},{"id":"cd53cdbf97b8f99c953dd3eda45eed25","title":"SpringMVC","content":"","slug":"Java/Java进阶/SpringMVC","date":"2022-07-19T12:33:50.130Z","categories_index":"Java框架","tags_index":"Java框架","author_index":"Hyc"},{"id":"af912e0d33a827f03582ef107fe8a87d","title